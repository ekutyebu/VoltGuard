# ==========================================
# VoltGuard Git Ignore List
# ==========================================

# PlatformIO compiled builds and cache
.pio/
.pioenvs/
.piolibdeps/
.clang_complete
.gcc-flags.json
*.tar.gz

# Node.js / Next.js dependency directories
node_modules/
/web/node_modules/
jspm_packages/

# Next.js build outputs
/web/.next/
/web/out/
.next/
out/

# Environment configurations containing keys/db secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
web/.env
web/.env.local

# Debug and execution logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editors & IDE variables
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Operating System files
Thumbs.db
db.files
.DS_Store
desktop.ini
